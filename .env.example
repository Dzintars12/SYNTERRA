# ==============================
# SYNTERRA Runtime Environment
# ==============================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Runtime
SYNTERRA_RUNTIME_MODE=development
SYNTERRA_DEFAULT_LANGUAGE=en
SYNTERRA_LOG_LEVEL=info

# Semantic Memory
SYNTERRA_MEMORY_PROVIDER=local
SYNTERRA_VECTOR_PROVIDER=local

# Future Database Layer
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Future Realtime Layer
REALTIME_PROVIDER=

# Future Authentication
AUTH_PROVIDER=
JWT_SECRET=
